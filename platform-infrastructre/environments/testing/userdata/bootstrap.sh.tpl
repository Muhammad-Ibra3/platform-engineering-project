#!/usr/bin/env bash

# ==============================================================================
# k3s + Argo CD bootstrap entrypoint
# This file is rendered by Terraform using templatefile().
# ==============================================================================

set -euxo pipefail
exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

export DEBIAN_FRONTEND=noninteractive
export K3S_VERSION="${k3s_version}"
export INSTALL_K3S_EXEC="server"

# ------------------------------------------------------------------------------
# Shared helper functions
# ------------------------------------------------------------------------------
${functions_sh}

# ------------------------------------------------------------------------------
# Base OS and kernel setup
# ------------------------------------------------------------------------------
${system_setup_sh}

# ------------------------------------------------------------------------------
# Install and configure k3s
# ------------------------------------------------------------------------------
${k3s_install_sh}

# ------------------------------------------------------------------------------
# Configure kubectl access and useful shell helpers for ubuntu user
# ------------------------------------------------------------------------------
${shell_setup_sh}

# ------------------------------------------------------------------------------
# Install and bootstrap Argo CD
# ------------------------------------------------------------------------------
${argocd_bootstrap}

# ------------------------------------------------------------------------------
# Clean up completed k3s bootstrap jobs in kube-system
# ------------------------------------------------------------------------------
${cleanup_sh}

echo "Bootstrap complete"